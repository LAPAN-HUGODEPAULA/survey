{
  "dependencies": {
    "npm": "^11.7.0"
  },
  "devDependencies": {
    "markdownlint": "^0.40.0"
  },
  "scripts": {
    "version:sync": "python3 tools/scripts/sync_version.py",
    "version:check": "python3 tools/scripts/sync_version.py --check",
    "release:prepare": "python3 tools/scripts/sync_version.py && python3 tools/scripts/sync_version.py --check",
    "dev:survey-frontend": "cd apps/survey-frontend && flutter run -d chrome --web-port 8080",
    "dev:survey-patient": "cd apps/survey-patient && flutter run -d chrome --web-port 8081",
    "dev:clinical-narrative": "cd apps/clinical-narrative && flutter run -d chrome --web-port 8082",
    "dev:survey-builder": "cd apps/survey-builder && flutter run -d chrome --web-port 8083"
  }
}
